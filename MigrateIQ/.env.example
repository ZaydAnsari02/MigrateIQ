
# Logging Configuration
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
PYTHONPATH=.

# Data Comparison Tolerance (percentage)
TOLERANCE_PCT=0.5

# Temporary Directory (for file extraction)
# Leave empty to use system temp directory
TEMP_DIR=

# Output Configuration
OUTPUT_DIR=./results
OUTPUT_FORMAT=json
# Options: json, csv, html (json is currently supported)

# Parser Configuration
# Hyper Database Support (set to false to skip Hyper extraction)
ENABLE_HYPER=true

# CSV Fallback (use when Hyper not available)
ENABLE_CSV_FALLBACK=true

# Verbose Mode (set to true for detailed logging)
VERBOSE=false

# Performance Settings
# Maximum file size to process (in MB)
MAX_FILE_SIZE_MB=5000

# Timeout for file operations (in seconds)
TIMEOUT_SECONDS=300

# Memory Limit (in MB, optional)
# MEMORY_LIMIT_MB=4096

# Batch Processing
# Process multiple file pairs (comma-separated)
# COMPARISON_PAIRS=file1.twbx:file1.pbix,file2.twbx:file2.pbix

# Notification Settings (optional)
NOTIFY_ON_FAIL=false
# NOTIFICATION_EMAIL=alerts@example.com
# NOTIFICATION_WEBHOOK=https://hooks.slack.com/...

# Testing Configuration
RUN_TESTS=true
TEST_TIMEOUT_SECONDS=60
TEST_VERBOSE=false

# Archive Settings
ARCHIVE_RESULTS=true
ARCHIVE_FORMAT=gzip
# Options: gzip, zip, tar

# Cleanup Settings
# Keep temporary files after processing
KEEP_TEMP_FILES=false

# Advanced Settings
# Enable detailed SQL/DAX expression parsing
DEEP_EXPRESSION_PARSING=false

# Case-sensitive comparison (default is case-insensitive)
CASE_SENSITIVE_COMPARISON=false

# Relationship strictness (0=lenient, 1=strict)
RELATIONSHIP_STRICTNESS=0

# Data type matching strictness
TYPE_MATCHING_STRICTNESS=1
# 0=lenient (int/decimal same), 1=strict (exact match)
